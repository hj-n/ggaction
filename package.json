{
  "name": "ggaction",
  "version": "0.0.0",
  "description": "A chart-authoring action library.",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./extension": {
      "types": "./types/extension.d.ts",
      "default": "./src/extension.js"
    },
    "./png": {
      "types": "./types/png.d.ts",
      "default": "./src/renderers/png.js"
    }
  },
  "scripts": {
    "test": "node --test test/unit/*/*.test.js test/unit/*/*/*.test.js test/contracts/*.test.js test/charts/*/*.test.js test/docs/*.test.js",
    "test:unit": "node --test test/unit/*/*.test.js test/unit/*/*/*.test.js",
    "test:contracts": "node --test test/contracts/*.test.js",
    "test:charts": "node --test test/charts/*/*.test.js",
    "test:docs": "node --test test/docs/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=src/**/*.js --test-coverage-lines=94 --test-coverage-branches=89 --test-coverage-functions=98 test/unit/*/*.test.js test/unit/*/*/*.test.js test/contracts/*.test.js test/charts/*/*.test.js test/docs/*.test.js",
    "test:render": "node test/support/artifacts.js && node --test test/charts/*/*.render.js",
    "docs:images": "node scripts/generate-doc-images.js",
    "docs:llms": "node scripts/generate-llm-docs.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2"
  }
}
